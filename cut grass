function Hatsu:_selectTab(tab)
    if self.ActiveTab then
        local prev = self.ActiveTab
        Util.tween(prev.Button, {BackgroundTransparency = 1}, 0.2)
        Util.tween(prev.Icon, {ImageColor3 = Theme.TextSecondary}, 0.2)
        Util.tween(prev.Label, {TextColor3 = Theme.TextSecondary}, 0.2)
        prev.Indicator.Visible = false
        prev.Container.Visible = false
    end
    self.ActiveTab = tab
    Util.tween(tab.Button, {BackgroundTransparency = 0.5, BackgroundColor3 = Theme.SectionBg}, 0.2)
    Util.tween(tab.Icon, {ImageColor3 = Theme.Accent}, 0.2)
    Util.tween(tab.Label, {TextColor3 = Theme.TextPrimary}, 0.2)
    tab.Indicator.Visible = true
    tab.Container.Visible = true
    self.ContentTitle.Text = tab.Name
    self.ContentSubtitle.Text = "Manage " .. tab.Name:lower() .. " settings"
end

