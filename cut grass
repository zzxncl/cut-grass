-- Helper: get all characters sorted by Cash (earning value) descending
local function GetCharactersByValue()
    local GameState = require(ReplicatedStorage.Modules.GameState)
    local Items = require(ReplicatedStorage.Modules.Items)
    local data = GameState.GetData2()
    if not data then return {} end
    
    -- Build value map from BrainrotSlots (placed characters earn Cash)
    local slotValues = {}
    for _, slot in pairs(data.BrainrotSlots or {}) do
        if type(slot) == "table" and slot.BrainrotName then
            local key = slot.BrainrotName .. "|" .. (slot.Variant or "Normal")
            local cash = tonumber(slot.Cash) or 0
            if not slotValues[key] or cash > slotValues[key] then
                slotValues[key] = cash
            end
        end
    end
    
    local chars = {}
    for idx, entry in pairs(data.Inventory or {}) do
        if type(entry) == "table" and entry.ItemName then
            local ok, itemData = pcall(function() return Items.GetItemData(entry.ItemName) end)
            if ok and itemData and itemData.Type == "Character" then
                local equipped = entry.EquippedCharacter or entry.CharacterId
                local variant = entry.Variant or "Normal"
                local key = entry.ItemName .. "|" .. variant
                local cash = slotValues[key] or 0
                
                -- Fallback: use rarity rank if no cash data
                local rarityRank = 0
                if itemData.Rarity and itemData.Rarity.Rarity then
                    local Rarities = require(ReplicatedStorage.Modules.Rarities)
                    for ri, r in ipairs(Rarities.Data) do
                        if r.Rarity == itemData.Rarity.Rarity then
                            rarityRank = ri
                            break
                        end
                    end
                end
                
                table.insert(chars, {
                    Entry = entry,
                    Index = idx,
                    Name = entry.ItemName,
                    Variant = variant,
                    Cash = cash,
                    RarityRank = rarityRank,
                    Equipped = equipped ~= nil,
                    ItemId = entry.ItemId,
                })
            end
        end
    end
    
    -- Sort by cash desc, then rarity desc as tiebreaker
    table.sort(chars, function(a, b)
        if a.Cash ~= b.Cash then return a.Cash > b.Cash end
        return a.RarityRank > b.RarityRank
    end)
    
    return chars
end

-- AUTO SHARD SHOP
local AutoShardShop = {
    Enabled = false,
    _thread = nil,
    _statusLabel = nil,
}

function AutoShardShop:SetStatus(text)
    if self._statusLabel then self._statusLabel:Set(text) end
end

function AutoShardShop:RunLoop()
    local GameState = require(ReplicatedStorage.Modules.GameState)
    local ShardsShop = require(ReplicatedStorage.Modules.ShardsShop)
    local soldOut = {} -- track items server rejected (out of stock)
    
    while self.Enabled do
        local data = GameState.GetData2()
        if not data then
            self:SetStatus("No data, waiting...")
            task.wait(3)
            continue
        end
        
        local shards = data.Shards or 0
        local bought = 0
        local allSoldOut = true
        
        for _, item in ipairs(ShardsShop.Data) do
            if not self.Enabled then break end
            
            -- Skip items we already know are sold out
            if soldOut[item.ItemName] then continue end
            
            local cost = 999999999
            pcall(function() cost = ShardsShop.GetItemCost(item.ItemName, data) end)
            
            -- Can't afford = skip (not sold out, just broke)
            if shards < cost then
                allSoldOut = false
                continue
            end
            
            allSoldOut = false
            
            -- Buy repeatedly until server rejects
            local itemBought = 0
            while self.Enabled and shards >= cost and itemBought < 50 do
                local prevShards = shards
                local buyOk = pcall(function()
                    GameState.SendEvent("BuyShardsShopItem", item.ItemName)
                end)
                
                if not buyOk then
                    soldOut[item.ItemName] = true
                    break
                end
                
                task.wait(0.3)
                
                data = GameState.GetData2()
                if not data then break end
                local newShards = data.Shards or 0
                
                if newShards < prevShards then
                    shards = newShards
                    itemBought = itemBought + 1
                    bought = bought + 1
                    self:SetStatus("Bought " .. item.ItemName .. " x" .. itemBought .. " (" .. tostring(shards) .. " shards left)")
                else
                    -- Server rejected = sold out, don't try again
                    soldOut[item.ItemName] = true
                    shards = newShards
                    break
                end
            end
        end
        
        if bought > 0 then
            self:SetStatus("Bought " .. bought .. " items! (" .. tostring(shards) .. " shards left)")
            task.wait(10)
        elseif allSoldOut then
            -- Everything is sold out, wait longer before rechecking
            self:SetStatus("All items sold out. Waiting 60s for restock...")
            soldOut = {} -- clear sold-out list so we re-check after wait
            task.wait(60)
        else
            self:SetStatus("Can't afford remaining items (" .. tostring(shards) .. " shards). Waiting 30s...")
            task.wait(30)
        end
    end
    self:SetStatus("Stopped.")
end

function AutoShardShop:Start()
    self.Enabled = true
    self._thread = task.spawn(function() self:RunLoop() end)
end

function AutoShardShop:Stop()
    self.Enabled = false
    if self._thread then pcall(function() task.cancel(self._thread) end); self._thread = nil end
    self:SetStatus("Stopped.")
end

-- AUTO DISMANTLE
local AutoDismantle = {
    Enabled = false,
    KeepTop = 3,
    _thread = nil,
    _statusLabel = nil,
}

function AutoDismantle:SetStatus(text)
    if self._statusLabel then self._statusLabel:Set(text) end
end

function AutoDismantle:RunLoop()
    local GameState = require(ReplicatedStorage.Modules.GameState)
    
    while self.Enabled do
        local chars = GetCharactersByValue()
        
        if #chars == 0 then
            self:SetStatus("No characters found. Waiting...")
            task.wait(5)
            continue
        end
        
        -- Skip equipped characters, then keep top N
        local kept = 0
        local toDismantleIds = {}
        
        for i, c in ipairs(chars) do
            if c.Equipped then
                -- Always keep equipped
            elseif kept < self.KeepTop then
                kept = kept + 1
            else
                -- Dismantle this one
                if c.ItemId then
                    table.insert(toDismantleIds, c.ItemId)
                else
                    local data = GameState.GetData2()
                    if data then
                        local idx = table.find(data.Inventory, c.Entry)
                        if idx then table.insert(toDismantleIds, idx) end
                    end
                end
            end
        end
        
        if #toDismantleIds == 0 then
            self:SetStatus("Keeping top " .. self.KeepTop .. " (" .. #chars .. " total). Nothing to dismantle.")
            task.wait(5)
            continue
        end
        
        self:SetStatus("Dismantling " .. #toDismantleIds .. " chars (keeping top " .. self.KeepTop .. ")...")
        GameState.SendEvent("SellCharacterForShards", toDismantleIds)
        task.wait(2)
    end
    self:SetStatus("Stopped.")
end

function AutoDismantle:Start()
    self.Enabled = true
    self._thread = task.spawn(function() self:RunLoop() end)
end

function AutoDismantle:Stop()
