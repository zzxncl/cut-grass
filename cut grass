local AutoStarFuser = {
    Enabled = false,
    _thread = nil,
    _statusLabel = nil,
}

function AutoStarFuser:SetStatus(text)
    if self._statusLabel then
        self._statusLabel:Set(text)
    end
    print("[Hatsu/StarFuse] " .. text)
end

function AutoStarFuser:GetGameState()
    local ok, GameState = pcall(function()
        return require(ReplicatedStorage.Modules.GameState)
    end)
    if ok then return GameState end
    return nil
end

function AutoStarFuser:FindFusableGroups()
    local GameState = self:GetGameState()
    if not GameState then return {} end
    local data = GameState.GetData2()
    if not data then return {} end
    
    local Items = nil
    pcall(function() Items = require(ReplicatedStorage.Modules.Items) end)
    
    local groups = {}
    
    -- Read from Inventory (not BrainrotSlots) - matches game's StarMachine logic
    for _, entry in pairs(data.Inventory or {}) do
        if type(entry) == "table" and entry.ItemName then
            -- Skip equipped characters
            if not entry.EquippedCharacter and not entry.CharacterId then
                -- Skip non-characters
                local isCharacter = true
                if Items then
                    local itemData = Items.GetItemData(entry.ItemName)
                    if not itemData or itemData.Type ~= "Character" then
                        isCharacter = false
                    end
                end
                
                if isCharacter then
                    -- Match game's star detection: StarsLevel or StarLevel or starsLevel
                    local stars = math.floor(tonumber(entry.StarsLevel or entry.StarLevel or entry.starsLevel or entry.starslevel or 0) or 0)
                    stars = math.clamp(stars, 0, 5)
                    
                    if stars < 5 then
                        local key = entry.ItemName .. "|" .. tostring(stars)
                        if not groups[key] then
                            groups[key] = {count = 0, name = entry.ItemName, starsLevel = stars}
                        end
                        groups[key].count = groups[key].count + 1
                    end
                end
            end
        end
    end
    
    local fusable = {}
    for _, group in pairs(groups) do
        if group.count >= 3 then
            table.insert(fusable, group)
        end
    end
    
    table.sort(fusable, function(a, b) return a.starsLevel < b.starsLevel end)
    return fusable
end

function AutoStarFuser:FuseGroup(group)
    local GameState = self:GetGameState()
    if not GameState then
        self:SetStatus("ERROR: GameState not available")
        return false
    end
    GameState.SendEvent("StarMachineFuseAll", group.name, group.starsLevel)
    return true
end

function AutoStarFuser:RunLoop()
    while self.Enabled do
        local fusable = self:FindFusableGroups()
        
        if #fusable == 0 then
            self:SetStatus("No fusable characters found. Waiting...")
            task.wait(3)
            continue
        end
        
        for _, group in ipairs(fusable) do
            if not self.Enabled then break end
            local fuseCount = math.floor(group.count / 3)
            self:SetStatus("Fusing " .. group.name .. " (" .. group.starsLevel .. "* x" .. group.count .. " -> " .. fuseCount .. "x " .. (group.starsLevel + 1) .. "*)")
            self:FuseGroup(group)
            task.wait(1)
        end
        
        if not self.Enabled then break end
        
        task.wait(1.5)
        local newFusable = self:FindFusableGroups()
        
        if #newFusable > 0 then
            self:SetStatus("Got characters back! Re-fusing " .. #newFusable .. " groups...")
            continue
        end
        
        self:SetStatus("All fusing complete. Monitoring...")
        task.wait(5)
    end
    
    self:SetStatus("Star Fuser stopped.")
end

function AutoStarFuser:Start()
    self.Enabled = true
    self._thread = task.spawn(function()
        self:RunLoop()
    end)
end

function AutoStarFuser:Stop()
    self.Enabled = false
    if self._thread then
        pcall(function() task.cancel(self._thread) end)
        self._thread = nil
    end
    self:SetStatus("Stopped.")
end

