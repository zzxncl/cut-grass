-- Check if any selected character exists in AvailableCharacters right now
-- Only returns characters physically inside the selected zone
function SelectionPickup:FindTargetCharacters()
    local charFolder = workspace:FindFirstChild("AvailableCharacters")
    if not charFolder then return {} end
    
    -- Get zone bounds for filtering
    local zoneData = ZONE_MAP[self.SelectedZone]
    local bounds = zoneData and AutoPickup:GetZoneBounds(zoneData.ZoneKey)
    
    local targets = {}
    for _, model in pairs(charFolder:GetChildren()) do
        if model:IsA("Model") then
            local charName = model:GetAttribute("CharacterName") or model.Name
            if self.SelectedCharacters[charName] then
                local hrp = model:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- Filter by zone bounds
                    if bounds then
                        local pos = hrp.Position
                        if pos.X < bounds.minX or pos.X > bounds.maxX or pos.Z < bounds.minZ or pos.Z > bounds.maxZ then
                            continue
                        end
                    end
                    
                    local prompt = hrp:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        table.insert(targets, {
                            Model = model,
                            HRP = hrp,
                            Prompt = prompt,
                            Position = hrp.Position,
                            Name = charName,
                        })
                    end
                end
            end
        end
    end
    return targets
end

-- Find ALL perk tokens across entire workspace (no radius limit)
function SelectionPickup:FindPerkTokens(zonePos, radius)
    -- Use zone-specific radius: calculate from zone's actual size + buffer
    -- If no radius given, compute from the selected zone's BasePart
    if not radius or radius < 50 then
        radius = 500 -- fallback
    end
    
    -- Get the actual zone size for a proper search radius
    local zoneData = ZONE_MAP[self.SelectedZone]
    if zoneData then
        local zoneFolder = workspace:FindFirstChild("GrassZones")
        if zoneFolder then
            local zf = zoneFolder:FindFirstChild(zoneData.ZoneKey)
            if zf then
                for _, p in pairs(zf:GetDescendants()) do
                    if p:IsA("BasePart") then
                        -- Zone radius = half the biggest dimension + 200 stud buffer for token spawns
                        radius = math.max(p.Size.X, p.Size.Z) / 2 + 200
                        zonePos = p.Position -- use the ACTUAL zone center
                        break
                    end
                end
            end
        end
    end
    
    local tokens = {}
    local tokenNames = {
        PerkModel = true,
        Luck = true, LuckyReroll = true, SuperLuckyReroll = true,
        Fusion = true, Starry = true, Walkspeed = true, WalkSpeed = true,
        Crystal = true, GrassBloom = true, Bomb = true, Rainbow = true,
        Bloom = true, Galaxy = true, Electro = true, Gold = true,
        Cross = true, Vertical = true, Reroll = true, Diamond = true, Level = true,
        Jackpot = true, JackpotPerk = true,
        LuckEffectPart = true, GalaxyLuckyBlock = true, ApexLuckyBlock = true,
        RerollMadnessPart = true,
    }
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") then
            local n = obj.Name
            local isToken = tokenNames[n]
                or n:find("Perk") or n:find("Reroll") or n:find("Token")
                or n:find("Luck") or n:find("Jackpot") or n:find("x50")
                or n:find("Lucky") or n:find("Block") or n:find("Madness")
                or n:find("Effect") or n:find("Galaxy") or n:find("Apex")
            if isToken then
                local part = obj:FindFirstChild("Part") or obj:FindFirstChildWhichIsA("BasePart")
                if part and part.Parent then
                    local dist = (part.Position - zonePos).Magnitude
                    if dist < radius then
                        table.insert(tokens, {
                            Model = obj,
                            Part = part,
                            Position = part.Position,
                            Name = n,
                        })
                    end
                end
            end
        end
    end
    -- Sort by distance to player so we grab nearest first
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        table.sort(tokens, function(a, b)
            return (a.Position - hrp.Position).Magnitude < (b.Position - hrp.Position).Magnitude
        end)
    end
    return tokens
end

-- Find nearby grass to cut
function SelectionPickup:FindNearbyGrass(zoneKey, playerPos, maxCount)
    maxCount = maxCount or 10
    local grassFolderName = "SpawnedGrass_" .. zoneKey
    local grassFolder = workspace:FindFirstChild(grassFolderName)
    if not grassFolder then return {} end
    
    local grasses = {}
    for _, g in pairs(grassFolder:GetChildren()) do
        if g:IsA("Model") then
            local part = g:FindFirstChild("Grass") or g:FindFirstChild("InvisibleBarrier")
            if part then
                local dist = (part.Position - playerPos).Magnitude
                table.insert(grasses, {Model = g, Part = part, Position = part.Position, Distance = dist})
            end
        end
    end
    
    -- Sort by distance
    table.sort(grasses, function(a, b) return a.Distance < b.Distance end)
    
    -- Return closest N
    local result = {}
    for i = 1, math.min(maxCount, #grasses) do
        result[i] = grasses[i]
    end
    return result
end

-- TP directly to grass level (no raycast - we want to be inside the grass)
function SelectionPickup:TeleportToGrass(grassPos)
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    -- Land right at grass position (slightly above ground)
    hrp.CFrame = CFrame.new(grassPos.X, grassPos.Y + 3, grassPos.Z)
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

-- Simulate weapon swings to cut grass
function SelectionPickup:SwingWeapon(times)
    local VU = game:GetService("VirtualUser")
    times = times or 5
    for i = 1, times do
        if not self.Enabled then return end
        if self._priorityTarget then return end
        pcall(function()
            VU:Button1Down(Vector2.new(400, 400), workspace.CurrentCamera.CFrame)
            task.wait(0.05)
            VU:Button1Up(Vector2.new(400, 400), workspace.CurrentCamera.CFrame)
        end)
        task.wait(0.15)
    end
end

-- Collect a token by standing on it (ZonePlus proximity detection)
function SelectionPickup:CollectToken(token)
    self._tokenCount = self._tokenCount + 1
    self:UpdateStats()
    self:SetStatus("Collecting token: " .. token.Name .. " (#" .. self._tokenCount .. ")")
    -- TP directly to the token position (ZonePlus triggers on proximity)
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp and token.Part and token.Part.Parent then
        hrp.CFrame = CFrame.new(token.Part.Position)
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
    -- Wait for ZonePlus to detect us inside the zone
    task.wait(1)
    -- If token still exists, try again slightly offset
    if token.Model and token.Model.Parent and hrp then
        hrp.CFrame = CFrame.new(token.Part.Position + Vector3.new(0, 1, 0))
        task.wait(0.5)
    end
end

-- Priority pickup: immediately grab a matching character
function SelectionPickup:PriorityPickup(target)
    self._pickupCount = self._pickupCount + 1
    self:UpdateStats()
    self:SetStatus("!! PRIORITY: " .. target.Name .. " found! (#" .. self._pickupCount .. ") Picking up...")
    AutoPickup:TeleportTo(target.Position)
    task.wait(0.3)
    AutoPickup:FireProximityPrompt(target.Prompt)
    task.wait(0.5)
    
    -- Go to safe zone and deliver
    self:SetStatus("Delivering " .. target.Name .. " to safe zone...")
    AutoPickup:TeleportTo(SAFE_ZONE_POS)
    task.wait(0.5)
    
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if remotes then
        local gamestateEvent = remotes:FindFirstChild("GamestateEvent")
        if gamestateEvent then
            gamestateEvent:FireServer("FinishCarry")
        end
    end
    
    self:SetStatus("Delivered " .. target.Name .. "!")
    task.wait(1)
end

-- Start watching for character spawns (priority interrupt)
function SelectionPickup:StartCharacterWatcher()
    local charFolder = workspace:FindFirstChild("AvailableCharacters")
    if not charFolder then return end
    
    self._charWatcher = charFolder.ChildAdded:Connect(function(model)
        if not self.Enabled then return end
        task.wait(0.5) -- let attributes load
        if not model:IsA("Model") then return end
        
        local charName = model:GetAttribute("CharacterName") or model.Name
        if self.SelectedCharacters[charName] then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local prompt = hrp:FindFirstChildOfClass("ProximityPrompt")
                if prompt then
                    self._priorityTarget = {
                        Model = model,
                        HRP = hrp,
                        Prompt = prompt,
                        Position = hrp.Position,
                        Name = charName,
                    }
                    self:SetStatus("!! " .. charName .. " SPAWNED! Interrupting...")
                end
            end
        end
    end)
end

function SelectionPickup:StopCharacterWatcher()
    if self._charWatcher then
        self._charWatcher:Disconnect()
        self._charWatcher = nil
    end
end

function SelectionPickup:RunLoop()
    local zoneData = ZONE_MAP[self.SelectedZone]
    if not zoneData then
        self:SetStatus("ERROR: Invalid zone selection")
        self.Enabled = false
        return
    end
    
    -- Build selected names for display
    local selectedNames = {}
    local hasSelection = false
    for name, v in pairs(self.SelectedCharacters) do
        if v then 
            table.insert(selectedNames, name) 
            hasSelection = true
        end
    end
    
    if not hasSelection then
        self:SetStatus("ERROR: No characters selected")
        self.Enabled = false
        return
    end
    
    -- Start watching for character spawns
    self:StartCharacterWatcher()
    
    -- Also check if any matching characters already exist
    local existingTargets = self:FindTargetCharacters()
    if #existingTargets > 0 then
        for _, target in ipairs(existingTargets) do
            if not self.Enabled then break end
            self:PriorityPickup(target)
        end
    end
    
    while self.Enabled do
        -- Step 1: TP to zone
        self:SetStatus("TP to " .. zoneData.Name .. " | Hunting: " .. table.concat(selectedNames, ", "))
        local zonePos = AutoPickup:GetZonePosition(zoneData.ZoneKey)
        if not zonePos then
            self:SetStatus("Zone not found, retrying...")
            task.wait(3)
            continue
        end
        
        AutoPickup:TeleportTo(zonePos)
        task.wait(0.5)
        
        -- Step 2: Farm loop - cut grass, collect tokens, watch for characters
        local farmCycles = 0
        while self.Enabled and farmCycles < 30 do -- Farm for ~30 cycles then re-check zone
            farmCycles = farmCycles + 1
            
            -- CHECK PRIORITY: matching character spawned?
            if self._priorityTarget then
                local pt = self._priorityTarget
                self._priorityTarget = nil
                if pt.Model and pt.Model.Parent then
                    self:PriorityPickup(pt)
                    -- After pickup, TP back to zone
                    AutoPickup:TeleportTo(zonePos)
                    task.wait(0.5)
                end
                continue
            end
            
            -- Also scan for existing matching characters
            local targets = self:FindTargetCharacters()
            if #targets > 0 then
                for _, target in ipairs(targets) do
                    if not self.Enabled then break end
                    self:PriorityPickup(target)
                end
                -- TP back to zone
                if self.Enabled then
                    AutoPickup:TeleportTo(zonePos)
                    task.wait(0.5)
                end
                continue
            end
            
            -- Collect any luck/perk tokens in zone
            local tokens = self:FindPerkTokens(zonePos, 300)
            if #tokens > 0 then
                for _, token in ipairs(tokens) do
                    if not self.Enabled then break end
                    if self._priorityTarget then break end -- interrupt for character
                    self:CollectToken(token)
                end
                -- TP back to grass area
                if self.Enabled and not self._priorityTarget then
                    AutoPickup:TeleportTo(zonePos)
                    task.wait(0.3)
                end
                continue
            end
            
            -- Find nearby grass and chain through multiple patches
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local nearGrass = self:FindNearbyGrass(zoneData.ZoneKey, hrp.Position, 15)
                if #nearGrass > 0 then
                    -- Chain through up to 5 grass patches per cycle
                    local cutThisCycle = 0
                    for gi = 1, math.min(5, #nearGrass) do
                        if not self.Enabled then break end
                        if self._priorityTarget then break end
                        
                        local g = nearGrass[gi]
                        if g.Model and g.Model.Parent then
                            self:SetStatus("Cutting grass (" .. self._grassCount .. " cut) | Watching for chars")
                            self:TeleportToGrass(g.Position)
                            task.wait(0.15)
                            self:SwingWeapon(6)
                            
                            -- Check if grass was destroyed
                            if not g.Model.Parent then
                                cutThisCycle = cutThisCycle + 1
                                self._grassCount = self._grassCount + cutThisCycle
                                self:UpdateStats()
                            end
                        end
                    end
                else
                    self:SetStatus("No grass nearby, roaming zone...")
                    local offset = Vector3.new(math.random(-80, 80), 0, math.random(-80, 80))
                    AutoPickup:TeleportTo(zonePos + offset)
                    task.wait(0.5)
                    self:SwingWeapon(5)
                end
            end
            
            task.wait(0.2)
        end
        
        task.wait(0.5)
    end
    
    self:StopCharacterWatcher()
    self:SetStatus("Selection Pickup stopped.")
end

function SelectionPickup:Start()
    self.Enabled = true
    self._priorityTarget = nil
    self._pickupCount = 0
    self._tokenCount = 0
    self._grassCount = 0
    self:UpdateStats()
    self._thread = task.spawn(function()
        self:RunLoop()
    end)
end

function SelectionPickup:Stop()
    self.Enabled = false
    self._priorityTarget = nil
    self:StopCharacterWatcher()
    if self._thread then
        pcall(function() task.cancel(self._thread) end)
        self._thread = nil
    end
    self:SetStatus("Stopped.")
end
