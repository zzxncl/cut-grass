            if delta.Magnitude > 5 then
                mbDidDrag = true
                mobileBtn.Position = UDim2.new(
                    mbStartPos.X.Scale, mbStartPos.X.Offset + delta.X,
                    mbStartPos.Y.Scale, mbStartPos.Y.Offset + delta.Y
                )
            end
        end
    end))
    mobileBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if not mbDidDrag then
                self.Toggled = not self.Toggled
                mainFrame.Visible = self.Toggled
                mobileBtn.Text = self.Toggled and "✕" or "☰"
            end
            mbDragStart = nil
            mbDidDrag = false
        end
    end)
    
