function AutoPickup:TeleportTo(position)
    local character = LocalPlayer.Character
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local hum = character:FindFirstChildOfClass("Humanoid")
    
    -- Disable fall damage states during TP
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    end
    
    local highPos = position + Vector3.new(0, 15, 0)
    hrp.CFrame = CFrame.new(highPos)
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
    task.wait(0.2)
    
    local rayOrigin = hrp.Position
    local rayDirection = Vector3.new(0, -200, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {character}
    
    local result = workspace:Raycast(rayOrigin, rayDirection, rayParams)
    
    if result then
        local groundPos = result.Position + Vector3.new(0, 4, 0)
        hrp.CFrame = CFrame.new(groundPos)
    else
        hrp.CFrame = CFrame.new(position + Vector3.new(0, 5, 0))
    end
    
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
    
    task.wait(0.15)
    hrp.Velocity = Vector3.new(0, 0, 0)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    
    -- Re-enable states after safe landing
    task.delay(1, function()
        if hum and hum.Parent then
            hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
        end
    end)
    
    return true
end

function AutoPickup:FireProximityPrompt(prompt)
    if fireproximityprompt then
        fireproximityprompt(prompt)
        return
    end
    local oldDist = prompt.MaxActivationDistance
    local oldReq = prompt.RequiresLineOfSight
    prompt.MaxActivationDistance = 9999
    prompt.RequiresLineOfSight = false
    prompt:InputHoldBegin()
    task.wait(prompt.HoldDuration + 0.1)
    prompt:InputHoldEnd()
    prompt.MaxActivationDistance = oldDist
    prompt.RequiresLineOfSight = oldReq
end

function AutoPickup:GetZonePosition(zoneKey)
    local zones = workspace:FindFirstChild("GrassZones")
    if not zones then return nil end
    local zoneFolder = zones:FindFirstChild(zoneKey)
    if not zoneFolder then return nil end
    for _, child in pairs(zoneFolder:GetDescendants()) do
        if child:IsA("BasePart") then
            return child.Position
        end
    end
    return nil
end

function AutoPickup:GetZoneBounds(zoneKey)
    local zones = workspace:FindFirstChild("GrassZones")
    if not zones then return nil end
    local zf = zones:FindFirstChild(zoneKey)
    if not zf then return nil end
    for _, p in pairs(zf:GetDescendants()) do
        if p:IsA("BasePart") then
            return {
                minX = p.Position.X - p.Size.X/2 - 50,
                maxX = p.Position.X + p.Size.X/2 + 50,
                minZ = p.Position.Z - p.Size.Z/2 - 30,
                maxZ = p.Position.Z + p.Size.Z/2 + 30,
            }
        end
    end
    return nil
end

function AutoPickup:FindCharactersInZone(zoneKey)
    local charFolder = workspace:FindFirstChild("AvailableCharacters")
    if not charFolder then return {} end
    
    -- Get zone bounds to filter characters by position
    local bounds = zoneKey and self:GetZoneBounds(zoneKey)
    
    local characters = {}
    for _, model in pairs(charFolder:GetChildren()) do
        if model:IsA("Model") then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Filter: only characters physically inside the selected zone
                if bounds then
                    local pos = hrp.Position
                    if pos.X < bounds.minX or pos.X > bounds.maxX or pos.Z < bounds.minZ or pos.Z > bounds.maxZ then
                        continue
                    end
                end
                
                local prompt = hrp:FindFirstChildOfClass("ProximityPrompt")
                if prompt then
                    table.insert(characters, {
                        Model = model,
                        HRP = hrp,
                        Prompt = prompt,
                        Position = hrp.Position,
                    })
                end
            end
        end
    end
    return characters
end

function AutoPickup:RunPickupLoop()
    local zoneData = ZONE_MAP[self.SelectedZone]
    if not zoneData then
        self:SetStatus("ERROR: Invalid zone")
        self.Enabled = false
        return
    end
    
    local pickupCount = self.PickupAmount
    
    while self.Enabled do
        self:SetStatus("TP to " .. zoneData.Name .. "...")
        local zonePos = self:GetZonePosition(zoneData.ZoneKey)
        if not zonePos then
            self:SetStatus("Zone not found, retrying...")
            task.wait(3)
            continue
        end
        
        self:TeleportTo(zonePos)
        task.wait(1)
        
        self:SetStatus("Scanning for characters...")
        local pickedUp = 0
        local alreadyPicked = {}
        
        for i = 1, pickupCount do
            if not self.Enabled then break end
            
            local characters = self:FindCharactersInZone(zoneData.ZoneKey)
            local target = nil
            
            for _, charData in ipairs(characters) do
                if not alreadyPicked[charData.Model] then
                    target = charData
                    break
                end
            end
            
            if not target then
                self:SetStatus("Waiting for more characters... (" .. pickedUp .. "/" .. pickupCount .. ")")
                task.wait(2)
                characters = self:FindCharactersInZone(zoneData.ZoneKey)
                for _, charData in ipairs(characters) do
                    if not alreadyPicked[charData.Model] then
                        target = charData
                        break
                    end
                end
                if not target then
                    self:SetStatus("Not enough characters, continuing with " .. pickedUp)
                    break
                end
            end
            
            self:SetStatus("Picking up " .. target.Model.Name .. " (" .. i .. "/" .. pickupCount .. ")")
            self:TeleportTo(target.Position)
            task.wait(0.3)
            self:FireProximityPrompt(target.Prompt)
            alreadyPicked[target.Model] = true
            pickedUp = pickedUp + 1
            task.wait(0.5)
        end
        
        if not self.Enabled then break end
        
        self:SetStatus("Returning to safe zone...")
        self:TeleportTo(SAFE_ZONE_POS)
        task.wait(0.5)
        
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            local gamestateEvent = remotes:FindFirstChild("GamestateEvent")
            if gamestateEvent then
                gamestateEvent:FireServer("FinishCarry")
            end
        end
        
        self:SetStatus("Delivered " .. pickedUp .. " characters. Looping...")
        task.wait(1.5)
    end
    
    self:SetStatus("Stopped.")
end

function AutoPickup:Start()
    self.Enabled = true
    self._thread = task.spawn(function()
        self:RunPickupLoop()
    end)
end

function AutoPickup:Stop()
    self.Enabled = false
    if self._thread then
        pcall(function() task.cancel(self._thread) end)
        self._thread = nil
    end
    self:SetStatus("Stopped.")
end

