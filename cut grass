local ZONE_CHARACTERS = {}

local function LoadZoneCharacters()
    local ok, GrassZones = pcall(function()
        return require(game.ReplicatedStorage.Modules.GrassZones)
    end)
    if ok and GrassZones and GrassZones.Data then
        for _, zone in ipairs(GrassZones.Data) do
            local chars = {}
            local seen = {}
            for _, spawn in ipairs(zone.Spawns or {}) do
                if not seen[spawn.CharacterName] then
                    seen[spawn.CharacterName] = true
                    table.insert(chars, spawn.CharacterName)
                end
            end
            for _, spawn in ipairs(zone.SequentialSpawns or {}) do
                if not seen[spawn.CharacterName] then
                    seen[spawn.CharacterName] = true
                    table.insert(chars, spawn.CharacterName)
                end
            end
            for _, spawn in ipairs(zone.SequentialFallbackSpawns or {}) do
                if not seen[spawn.CharacterName] then
                    seen[spawn.CharacterName] = true
                    table.insert(chars, spawn.CharacterName)
                end
            end
            ZONE_CHARACTERS[zone.ZoneName] = chars
        end
        print("[Hatsu] Loaded " .. tostring(#GrassZones.Data) .. " zones from GrassZones module")
    else
        print("[Hatsu] WARNING: Could not load GrassZones module")
    end
end

