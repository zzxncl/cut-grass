-- ANTI-AFK SYSTEM
-- ============================================================
local AntiAFK = {
    Enabled = false,
    _thread = nil,
    _statusLabel = nil,
}

function AntiAFK:SetStatus(text)
    if self._statusLabel then
        self._statusLabel:Set(text)
    end
end

function AntiAFK:RunLoop()
    local VirtualUser = game:GetService("VirtualUser")
    local idleConns = {}
    
    -- Hook the Idled event (fires at 20 min idle)
    pcall(function()
        idleConns[#idleConns+1] = LocalPlayer.Idled:Connect(function(idleTime)
            if self.Enabled then
                -- Multiple anti-kick methods at once
                pcall(function()
                    VirtualUser:CaptureController()
                    VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
                    task.wait(0.1)
                    VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
                end)
                pcall(function()
                    VirtualUser:ClickButton1(Vector2.new(400, 300), workspace.CurrentCamera.CFrame)
                end)
                -- Keypress simulation (W key tap)
                pcall(function()
                    keypress(0x57) -- W
                    task.wait(0.15)
                    keyrelease(0x57)
                end)
                self:SetStatus("Anti-AFK: Blocked idle kick (" .. math.floor(idleTime) .. "s)")
            end
        end)
    end)
    
    local cycles = 0
    while self.Enabled do
        cycles = cycles + 1
        
        -- Method 1: VirtualUser camera + click
        pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.1)
            VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
        
        -- Method 2: Keypress simulation (tap spacebar then W)
        pcall(function()
            keypress(0x20) -- Space
            task.wait(0.1)
            keyrelease(0x20)
            task.wait(0.2)
            keypress(0x57) -- W
            task.wait(0.15)
            keyrelease(0x57)
        end)
        
        -- Method 3: Micro-movement (prevents position-based idle detection)
        pcall(function()
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hrp and hum then
                    -- Small jump + wiggle
                    hum.Jump = true
                    task.wait(0.3)
                    hum:Move(Vector3.new(0.1, 0, 0))
                    task.wait(0.2)
                    hum:Move(Vector3.new(-0.1, 0, 0))
                    task.wait(0.2)
                    hum:Move(Vector3.new(0, 0, 0))
                end
            end
        end)
        
        -- Method 4: Mouse click simulation
        pcall(function()
            mouse1click()
        end)
        
        self:SetStatus("Anti-AFK active (" .. cycles .. " cycles, every 45s)")
        task.wait(45) -- More frequent than before (was 55s, Roblox kicks at ~20min)
    end
    
    for _, conn in ipairs(idleConns) do pcall(function() conn:Disconnect() end) end
    self:SetStatus("Anti-AFK stopped.")
end

function AntiAFK:Start()
    self.Enabled = true
    self._thread = task.spawn(function()
        self:RunLoop()
    end)
    self:SetStatus("Anti-AFK active")
end

function AntiAFK:Stop()
    self.Enabled = false
    if self._thread then
        pcall(function() task.cancel(self._thread) end)
        self._thread = nil
    end
    self:SetStatus("Anti-AFK stopped.")
end

