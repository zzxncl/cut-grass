        dropBtn.Size = UDim2.new(0.55, 0, 0, 26)
        dropBtn.Position = UDim2.new(0.45, 0, 0.5, -13)
        dropBtn.BorderSizePixel = 0
        dropBtn.Font = Theme.Font
        dropBtn.Text = "  Select Characters v"
        dropBtn.TextColor3 = Theme.TextPrimary
        dropBtn.TextSize = 11
        dropBtn.TextXAlignment = Enum.TextXAlignment.Left
        dropBtn.AutoButtonColor = false
        dropBtn.ZIndex = 10
        dropBtn.Parent = row
        Util.corner(dropBtn, UDim.new(0, 6))
        Util.stroke(dropBtn, Theme.Border, 1)
        
        local screenGui = sectionFrame:FindFirstAncestorOfClass("ScreenGui")
        
        local overlay = Instance.new("TextButton")
        overlay.BackgroundTransparency = 1
        overlay.Size = UDim2.new(1, 0, 1, 0)
        overlay.BorderSizePixel = 0
        overlay.Text = ""
        overlay.ZIndex = 90
        overlay.Visible = false
        overlay.Parent = screenGui
        
        local optionsFrame = Instance.new("Frame")
        optionsFrame.BackgroundColor3 = Theme.DropdownBg
        optionsFrame.BorderSizePixel = 0
        optionsFrame.Visible = false
        optionsFrame.ZIndex = 100
        optionsFrame.ClipsDescendants = true
        optionsFrame.Parent = screenGui
        Util.corner(optionsFrame, UDim.new(0, 6))
        Util.stroke(optionsFrame, Theme.Border, 1)
        
        local maxVis = math.min(#options, 8)
        local ddHeight = math.max(maxVis * 26, 52)
        
        local optScroll = Instance.new("ScrollingFrame")
        optScroll.BackgroundTransparency = 1
        optScroll.Size = UDim2.new(1, 0, 1, 0)
        optScroll.BorderSizePixel = 0
        optScroll.ScrollBarThickness = 2
        optScroll.ScrollBarImageColor3 = Theme.AccentDim
        optScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        optScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        optScroll.ZIndex = 101
        optScroll.Parent = optionsFrame
        
        local scrollLayout = Instance.new("UIListLayout")
        scrollLayout.SortOrder = Enum.SortOrder.LayoutOrder
        scrollLayout.Parent = optScroll
        
        local function updateText() local c = getCount(); dropBtn.Text = c == 0 and "  Select Characters v" or ("  " .. c .. " Selected v") end
        local function closeDD() isOpen = false; optionsFrame.Visible = false; overlay.Visible = false end
        overlay.MouseButton1Click:Connect(closeDD)
        
        local function rebuildOptions(newOpts)
            for _, child in pairs(optScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
            selectedMap = {}
            for i, opt in ipairs(newOpts) do
                local optBtn = Instance.new("TextButton")
                optBtn.BackgroundColor3 = Theme.DropdownBg
                optBtn.Size = UDim2.new(1, 0, 0, 26)
                optBtn.BorderSizePixel = 0
                optBtn.Font = Theme.Font
                optBtn.Text = "  [ ] " .. opt
                optBtn.TextColor3 = Theme.TextSecondary
                optBtn.TextSize = 11
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                optBtn.AutoButtonColor = false
                optBtn.LayoutOrder = i
                optBtn.ZIndex = 102
                optBtn.Parent = optScroll
                optBtn.MouseEnter:Connect(function() Util.tween(optBtn, {BackgroundColor3 = Theme.DropdownHover}, 0.1) end)
                optBtn.MouseLeave:Connect(function() Util.tween(optBtn, {BackgroundColor3 = Theme.DropdownBg}, 0.1) end)
                optBtn.MouseButton1Click:Connect(function()
                    selectedMap[opt] = not selectedMap[opt]
                    optBtn.Text = selectedMap[opt] and ("  [x] " .. opt) or ("  [ ] " .. opt)
                    optBtn.TextColor3 = selectedMap[opt] and Theme.Accent or Theme.TextSecondary
                    updateText()
                    callback(selectedMap)
                end)
            end
            maxVis = math.min(#newOpts, 8)
            ddHeight = math.max(maxVis * 26, 52)
            updateText()
        end
        
        rebuildOptions(options)
        
        local function openDD()
            local p = dropBtn.AbsolutePosition
            local s = dropBtn.AbsoluteSize
            optionsFrame.Position = UDim2.new(0, p.X, 0, p.Y + s.Y + 2)
            optionsFrame.Size = UDim2.new(0, s.X, 0, ddHeight)
            isOpen = true; overlay.Visible = true; optionsFrame.Visible = true
        end
        
        dropBtn.MouseButton1Click:Connect(function() if isOpen then closeDD() else openDD() end end)
        
        return {
            SetOptions = function(_, newOpts) rebuildOptions(newOpts) end,
            GetSelected = function() return selectedMap end,
        }
    end
    
    function SectionAPI:AddLabel(text)
        elementOrder = elementOrder + 1
        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 0, 16)
        lbl.Font = Theme.FontLight
        lbl.Text = text or ""
        lbl.TextColor3 = Theme.TextMuted
        lbl.TextSize = 11
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.LayoutOrder = elementOrder
        lbl.Parent = sectionFrame
        return { Set = function(_, newText) lbl.Text = newText end }
    end
    
    function SectionAPI:AddButton(btnConfig)
        btnConfig = btnConfig or {}
        elementOrder = elementOrder + 1
        local row = Instance.new("TextButton")
        row.BackgroundColor3 = Theme.AccentDim
        row.Size = UDim2.new(1, 0, 0, 32)
        row.BorderSizePixel = 0
        row.Font = Theme.Font
        row.Text = btnConfig.Name or "Button"
        row.TextColor3 = Theme.TextPrimary
        row.TextSize = 13
        row.AutoButtonColor = false
        row.LayoutOrder = elementOrder
        row.Parent = sectionFrame
        Util.corner(row, UDim.new(0, 6))
        row.MouseEnter:Connect(function() Util.tween(row, {BackgroundColor3 = Theme.Accent}, 0.15) end)
        row.MouseLeave:Connect(function() Util.tween(row, {BackgroundColor3 = Theme.AccentDim}, 0.15) end)
        row.MouseButton1Click:Connect(function()
            if btnConfig.Callback then btnConfig.Callback() end
        end)
    end
    
    return SectionAPI
end

function Hatsu:Destroy()
    for _, conn in ipairs(self.Connections) do
        if conn and conn.Connected then conn:Disconnect() end
    end
    if self.ScreenGui then self.ScreenGui:Destroy() end
end

